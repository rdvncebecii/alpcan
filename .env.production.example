# AlpCAN — Production Environment Variables
# Copy to .env.production and fill with real values
# NEVER commit .env.production to git!

# ── Database ──
DATABASE_URL=postgresql+asyncpg://alpcan:CHANGE_THIS_DB_PASSWORD@db:5432/alpcan
POSTGRES_USER=alpcan
POSTGRES_PASSWORD=CHANGE_THIS_DB_PASSWORD
POSTGRES_DB=alpcan

# ── Redis ──
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# ── Backend ──
SECRET_KEY=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000

# ── Frontend ──
NEXT_PUBLIC_API_URL=https://alpcan.alpiss.net/api/v1
NEXT_PUBLIC_ORTHANC_URL=https://alpcan.alpiss.net/orthanc

# ── CORS ──
CORS_ORIGINS=["https://alpcan.alpiss.net"]

# ── Orthanc ──
ORTHANC_URL=http://orthanc:8042

# ── ML ──
MODEL_WEIGHTS_DIR=/app/ml/weights
INFERENCE_DEVICE=cpu
ML_CONFIG_PATH=/app/ml/configs/models.yaml
