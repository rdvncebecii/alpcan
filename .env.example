# AlpCAN Environment Variables
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=postgresql+asyncpg://alpcan:alpcan_secret@db:5432/alpcan
POSTGRES_USER=alpcan
POSTGRES_PASSWORD=alpcan_secret
POSTGRES_DB=alpcan

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
SECRET_KEY=change-this-to-a-random-secret-key
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_ORTHANC_URL=http://localhost:8042

# Orthanc DICOM Server
ORTHANC_HTTP_PORT=8042
ORTHANC_DICOM_PORT=4242

# CORS
CORS_ORIGINS=["http://localhost:3000","https://alpcan.alpiss.net"]

# ML
MODEL_WEIGHTS_DIR=/app/ml/weights
INFERENCE_DEVICE=cpu
